# ═══════════════════════════════════════════════════════════════════════════════
# opencode-memnet — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# Variables marked Required: yes MUST be set before starting the server.
# Variables with defaults can be left as-is unless you need to customize them.
#
# Secret values (EMBEDDING_API_KEY, MEMORY_API_KEY) support special prefixes:
#   - Plain value:    sk-abc123...
#   - File reference: file:///path/to/secret  (reads contents of file)
#   - Env reference:  env://OTHER_ENV_VAR     (reads another env variable)
#
# ═══════════════════════════════════════════════════════════════════════════════


# ── Server ─────────────────────────────────────────────────────────────────────

# EXTERNAL_HOST
# IP address or hostname on the HOST machine to bind the server port to.
# This controls which network interfaces the server is accessible from.
# Options: localhost | 127.0.0.1 | 0.0.0.0 | <any-ip-address>
# Default: localhost (only accessible from this machine — most secure)
# Set to 0.0.0.0 to allow access from other machines on your network (e.g. LAN access)
# Only used by docker-compose; ignored when running the server directly.
# Required: no
EXTERNAL_HOST=localhost

# HOST_PORT
# Port number on the HOST machine that maps to the container port.
# This is the port you use to access the server from outside Docker.
# Default: 4747
# Only used by docker-compose; ignored when running the server directly.
# Required: no
HOST_PORT=4747

# SERVER_PORT
# Port the HTTP server listens on INSIDE the container (or directly when not
# using Docker). In docker-compose this is the container-side port mapping.
# Default: 4747
# Required: no
SERVER_PORT=4747

# SERVER_HOST
# Network interface the server binds to INSIDE the container. Use "0.0.0.0" for
# all interfaces (required for Docker) or "127.0.0.1" for local-only access
# (only when running outside Docker).
# Default: 0.0.0.0
# Required: no
SERVER_HOST=0.0.0.0

# SERVER_API_KEY
# API key used to authenticate all /api/* requests. Clients must send this as
# a Bearer token. Choose a strong random string for production.
# Optional if both DISABLE_WEBUI_AUTH and DISABLE_CLIENT_AUTH are set to "true".
# Default: (empty — will fail validation unless both auth modes are disabled)
# Required: yes (unless both auth modes are disabled)
# Example: my-secret-api-key-change-me
SERVER_API_KEY=

# DISABLE_WEBUI_AUTH
#
# Normally, when you open the WebUI (the browser dashboard at http://localhost:4747),
# you need to enter your API key before you can see or do anything. This setting
# turns that requirement OFF.
#
# What happens when you set this to "true":
#   - Anyone who can reach the server URL can open the WebUI and see everything —
#     all memories, all profiles, all stats. No login or API key needed.
#   - The browser dashboard still has an "API Settings" panel, but it will show
#     "Auth disabled" and auto-load your data immediately.
#
# Why would you use this?
#   - You're running the server on localhost (your own machine) and don't need
#     a password since only you can access it.
#   - You've put the server behind something that already handles auth — for
#     example, a reverse proxy like Caddy or Nginx with HTTP basic auth, a VPN,
#     or a firewall that only allows your IP address.
#   - You're on a trusted private network (e.g., home LAN) and want convenience
#     over security.
#
# Why would you NOT use this?
#   - If the server is reachable from the internet without any other protection,
#     anyone could read all stored memories and profiles, or add/delete memories.
#     That's bad — memories can contain sensitive project context and personal
#     preferences.
#
# Default: false (API key IS required)
# Required: no
# Example: DISABLE_WEBUI_AUTH=true
DISABLE_WEBUI_AUTH=false

# DISABLE_CLIENT_AUTH
#
# Normally, the opencode-memnet plugin (running inside your AI coding agent) needs
# to send an API key with every request to the server — a sort of password that
# proves "hey, I'm allowed to talk to this server." This setting turns that
# requirement OFF.
#
# What happens when you set this to "true":
#   - The plugin can connect to the server and read/write memories WITHOUT
#     sending an API key. The plugin config file only needs the server URL,
#     not an API key.
#   - ANY client that can reach the server can add, search, and delete memories.
#
# Why would you use this?
#   - You're running everything locally (server + client on the same machine)
#     and don't need inter-process authentication.
#   - You have many AI agents connecting and don't want to manage API keys for
#     each one.
#   - The server is behind a reverse proxy or VPN that already restricts access.
#
# Why would you NOT use this?
#   - If the server is on a network that other people or processes can reach,
#     they could connect to it and read or tamper with your AI's memory store.
#
# Note: You can mix and match. For example, you can set DISABLE_WEBUI_AUTH=true
# (open browser access) but leave DISABLE_CLIENT_AUTH=false (plugin still needs
# the key). Or vice versa. If you set BOTH to "true", then SERVER_API_KEY becomes
# optional — you can omit it entirely.
#
# Default: false (API key IS required)
# Required: no
# Example: DISABLE_CLIENT_AUTH=true
DISABLE_CLIENT_AUTH=false

# WEB_SERVER_ALLOWED_ORIGIN
# CORS Allowed-Origin header value. Use "*" to allow all origins, or specify
# a specific origin like "https://myapp.example.com" for production.
# Default: *
# Required: no
WEB_SERVER_ALLOWED_ORIGIN=*


# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────

# POSTGRES_URL
# Full PostgreSQL connection string. For Docker Compose with the bundled db
# service, use: postgresql://opencode:opencode@db:5432/opencode_mem
# For external databases, provide the full URL including host, port, user,
# password, and database name.
# Default: (empty — will fail validation)
# Required: yes
# Example: postgresql://user:password@localhost:5432/opencode_mem
POSTGRES_URL=

# POSTGRES_SSL
# SSL mode for the PostgreSQL connection. Set to "false" (the string) for local
# Docker development. Set to "require" for production with managed databases.
# Options: | require | false |
# Default: require
# Required: no
POSTGRES_SSL=require

# POSTGRES_MAX_CONNECTIONS
#
# How many simultaneous database connections the server can use. Each
# connection handles one query at a time. For a single-user local setup,
# 10 is plenty. If you're running a multi-user server or see "too many
# clients" errors in the server logs, raise to 20–50. Don't exceed
# your database server's own max_connections setting (default is 100
# in most PostgreSQL installs).
# Default: 10
# Required: no
POSTGRES_MAX_CONNECTIONS=10

# POSTGRES_IDLE_TIMEOUT_SECONDS
#
# How long an unused database connection stays open before the pool closes
# it to free up resources. Lower values free database memory faster; higher
# values avoid the overhead of re-establishing connections when traffic
# resumes. 30 seconds is fine for almost everyone. Raise to 60–120 if
# you find "connection closed unexpectedly" errors during bursts of
# activity followed by quiet periods.
# Default: 30
# Required: no
POSTGRES_IDLE_TIMEOUT_SECONDS=30

# POSTGRES_CONNECT_TIMEOUT_SECONDS
#
# How long to wait for a new database connection before giving up. If the
# database can't respond in this time, the server logs an error and that
# particular request fails (no crash, no retry built-in). 10 seconds is
# fine locally. Increase to 20–30 for remote databases (e.g., cloud-hosted
# PostgreSQL on a different continent).
# Default: 10
# Required: no
POSTGRES_CONNECT_TIMEOUT_SECONDS=10

# POSTGRES_VECTOR_TYPE
#
# Storage format for embedding vectors.
#   vector   — 32-bit floating point (full precision, default). Best recall.
#   halfvec  — 16-bit floating point (half the storage, ~50% less RAM).
#              Recall is ~99.9% identical to full precision — the quality
#              difference is negligible for most use cases. Good choice
#              if you're storage- or RAM-constrained.
#
# ⚠ Changing this after memories exist requires rebuilding the entire
#   vector index and re-running migrations.
# Options: | vector | halfvec |
# Default: vector
# Required: no
POSTGRES_VECTOR_TYPE=vector

# POSTGRES_HNSW_EF_SEARCH
#
# Controls how thoroughly each vector search examines the database. Think of
# it like "pages to flip through" when looking up a word in a dictionary
# index. Higher = more thorough (finds more matches) but slower per query.
# This is a query-time setting — changes take effect immediately, no index
# rebuild needed.
#
# Recommended by dataset size:
#   64   — under 1,000 memories (fastest, good enough)
#   128  — 1,000–10,000 memories (default, balanced)
#   256  — 10,000–100,000 memories
#   512  — 100,000+ memories (slowest, best recall)
#
# Query latency at 10K memories: ~1ms@64, ~2ms@128, ~4ms@256, ~8ms@512.
# RAM impact: negligible (slightly more CPU per query, no extra memory).
# For most users, 128 is fine. Only raise this if searches are missing
# results you know should be there.
# Default: 128
# Required: no
POSTGRES_HNSW_EF_SEARCH=128

# POSTGRES_HNSW_EF_CONSTRUCTION
#
# Controls how much work goes into building the vector search index. Think
# of it like "how carefully the dictionary is assembled." Higher = better
# search recall later, but slower index creation (only matters when you
# first build it or add large batches of new vectors). Does NOT affect
# query speed — that's controlled by ef_search above.
#
# As a rule of thumb, set this to roughly 2× your ef_search:
#   128  — under 1,000 memories (~10s build)
#   256  — 1,000–10,000 memories (~30s–2min build, default)
#   512  — 10,000–100,000 memories (~5–8min build)
#   800  — 100,000+ memories (~15–20min build)
#
# ⚠ Changing this after the index exists has no effect! You must rebuild
#   the index for a new value to take effect. For most users, the default
#   is perfectly fine.
# Default: 256
# Required: no
POSTGRES_HNSW_EF_CONSTRUCTION=256


# ── Embedding ─────────────────────────────────────────────────────────────────

# EMBEDDING_API_URL
# Base URL for the OpenAI-compatible embedding API endpoint.
# For OpenAI: https://api.openai.com/v1
# For self-hosted (e.g., Ollama): http://localhost:11434/v1
# Default: (empty — will fail validation)
# Required: yes
# Example: https://api.openai.com/v1
EMBEDDING_API_URL=

# EMBEDDING_MODEL
# Name of the embedding model to use. Dimensions are auto-detected for known
# models (see EMBEDDING_DIMENSIONS below).
# Common choices: text-embedding-3-small, text-embedding-3-large, voyage-3
# Default: (empty — will fail validation)
# Required: yes
# Example: text-embedding-3-small
EMBEDDING_MODEL=

# EMBEDDING_API_KEY
# API key for the embedding service. Supports secret prefixes:
#   - Plain:    sk-abc123...
#   - File:     file:///run/secrets/embedding_key
#   - Env ref:  env://MY_EMBEDD_KEY
# Also falls back to OPENAI_API_KEY if this is not set.
# Default: (empty — will fail validation)
# Required: yes (or set OPENAI_API_KEY)
# Example: sk-...
EMBEDDING_API_KEY=

# EMBEDDING_DIMENSIONS
#
# The "width" of the mathematical fingerprint each memory gets. More
# dimensions = richer representation and better matching, but more disk
# space, more RAM, and slower searches (about 4 bytes per dimension per
# memory). Leave set to 0 — it auto-detects from your EMBEDDING_MODEL,
# which is correct for 99% of users.
#
# ⚠ Only override if you're using a custom model not in the list below.
#   Setting the wrong dimension breaks all searches — vectors of different
#   sizes can't be compared.
#
# Storage per 100K memories:
#   384 dims  ≈ 150 MB       768 dims  ≈ 300 MB
#   1024 dims ≈ 400 MB       1536 dims ≈ 600 MB       3072 dims ≈ 1.2 GB
#
# Auto-detected dimensions for known models:
#   text-embedding-3-small          → 1536
#   text-embedding-3-large          → 3072
#   text-embedding-ada-002          → 1536
#   embed-english-v3.0              → 1024
#   embed-multilingual-v3.0         → 1024
#   embed-english-light-v3.0        → 384
#   embed-multilingual-light-v3.0   → 384
#   text-embedding-004              → 768
#   text-multilingual-embedding-002 → 768
#   voyage-3                        → 1024
#   voyage-3-lite                   → 512
#   voyage-code-3                   → 1024
# Unknown models default to 1024.
#
# Default: auto-detected from EMBEDDING_MODEL (set to 0 for auto)
# Required: no
EMBEDDING_DIMENSIONS=0

# EMBEDDING_MAX_TOKENS_CONTENT
#
# How much of each memory's text gets turned into a vector fingerprint.
# ~1 token ≈ ¾ of an English word, so 2048 tokens ≈ 1,500 words (about
# 2–3 pages of text). Text beyond this is cut off (see TRUNCATION_CONTENT
# for which side). Longer text = better embeddings but uses more API
# tokens per call, increasing cost. Most embedding models handle 2048+
# tokens, but check your model's docs before raising this.
# Default: 2048 (≈1,500 words)
# Required: no
EMBEDDING_MAX_TOKENS_CONTENT=2048

# EMBEDDING_MAX_TOKENS_TAGS
#
# Maximum text size for tag embeddings. 256 tokens ≈ 190 words. Tags are
# short by design (keywords and labels), so this default is rarely worth
# changing. Raise it only if your tagging system uses long descriptive
# tags (e.g., full sentences instead of keywords).
# Default: 256 (≈190 words)
# Required: no
EMBEDDING_MAX_TOKENS_TAGS=256

# EMBEDDING_MAX_TOKENS_QUERY
#
# Maximum text size for search query embeddings. 512 tokens ≈ 380 words.
# Typical search queries are 5–20 words, so this is generous by default.
# Only raise it if you're using long-form natural-language queries (e.g.,
# pasting paragraphs as search terms).
# Default: 512 (≈380 words)
# Required: no
EMBEDDING_MAX_TOKENS_QUERY=512

# EMBEDDING_MAX_TOKENS_MIGRATION
#
# Maximum text size per memory during database migration (converting old
# file-based memories into the new PostgreSQL format). 2048 tokens ≈ 1,500
# words. This only matters once, during import — set it the same as
# EMBEDDING_MAX_TOKENS_CONTENT unless you have specific migration needs.
# Default: 2048 (≈1,500 words)
# Required: no
EMBEDDING_MAX_TOKENS_MIGRATION=2048

# EMBEDDING_TRUNCATION_CONTENT
#
# When a memory's text is too long (exceeds EMBEDDING_MAX_TOKENS_CONTENT),
# which part do we keep?
#   right = keep the END of the text (default, usually best for memories —
#           conclusions and summaries live at the end)
#   left  = keep the START of the text (better if your memories open with
#           the most important information)
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_CONTENT=right

# EMBEDDING_TRUNCATION_TAGS
#
# When tag text is too long for the embedding model, which side to keep.
#   right = keep the END (default)
#   left  = keep the START
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_TAGS=right

# EMBEDDING_TRUNCATION_QUERY
#
# When a search query is too long, which side to keep. Queries typically
# start with the most important keywords, so "left" can make more sense
# here — it keeps the beginning where users put their key terms.
#   left  = keep the START of the query (usually better for search terms)
#   right = keep the END of the query (default)
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_QUERY=right

# EMBEDDING_TRUNCATION_MIGRATION
#
# When migrating memories from a file database, which side to keep if the
# text is too long for the embedding model.
#   right = keep the END (default)
#   left  = keep the START
# Options: | left | right |
# Default: right
# Required: no
EMBEDDING_TRUNCATION_MIGRATION=right


# ── Memory / AI ───────────────────────────────────────────────────────────────

# SIMILARITY_THRESHOLD
#
# How closely a memory must match your query to be included in results.
# Think of it as a "relevance filter" from 0.0 (accept everything) to 1.0
# (exact match only). Higher = fewer but more relevant results.
#
# Practical guide:
#   0.4  — loose: returns many results, some may feel off-topic. Good for
#          brainstorming or when you know the memory exists but can't
#          remember the exact wording.
#   0.5  — relaxed: still broad, some noise. Good for creative exploration.
#   0.6  — moderate: balanced precision vs. recall (default, good for most).
#   0.7  — strict: mostly relevant results, fewer total matches. Good when
#          you want only clearly related memories.
#   0.8  — very strict: only memories strongly related to your query. May
#          miss vaguely useful context.
#   0.9+ — near-exact: only highly similar content passes. Use when false
#          positives are worse than missed results.
#
# Default: 0.6
# Required: no
SIMILARITY_THRESHOLD=0.6

# MAX_MEMORIES
#
# How many memories are injected into the AI agent's context per request.
# Each memory typically uses 100–500 tokens. At 10 memories, you're adding
# roughly 1,000–5,000 tokens of context (out of the AI model's total
# context window, typically 128K–200K tokens). More memories = richer
# context for the AI, but also slower responses and higher API costs
# (you pay for every token in the context window). Recommended:
#   5  — minimal context, fast, cheap
#   10 — balanced (default)
#   20 — rich context, worth it when you have many relevant memories
#   50 — only if your model has a very large context window (200K+)
# Default: 10
# Required: no
MAX_MEMORIES=10

# INJECT_PROFILE
# Whether to include the learned user profile in context injection.
# Set to "false" to disable profile injection.
# Default: true
# Required: no
INJECT_PROFILE=true

# MEMORY_MODEL
# Chat model used for memory extraction and auto-capture. Required for
# auto-capture functionality. Any OpenAI-compatible Chat Completions model.
# Default: (not set — auto-capture disabled)
# Required: no (but needed for auto-capture)
# Example: gpt-4o-mini
MEMORY_MODEL=

# MEMORY_API_URL
# Base URL for the OpenAI-compatible Chat Completions API used for memory
# extraction. Can be the same as EMBEDDING_API_URL or a different endpoint.
# Default: (not set — auto-capture disabled)
# Required: no (but needed for auto-capture)
# Example: https://api.openai.com/v1
MEMORY_API_URL=

# MEMORY_API_KEY
# API key for the memory extraction Chat Completions API. Supports secret
# prefixes:
#   - Plain:    sk-abc123...
#   - File:     file:///run/secrets/memory_key
#   - Env ref:  env://MY_MEMORY_KEY
# Default: (not set — auto-capture disabled)
# Required: no (but needed for auto-capture)
# Example: sk-...
MEMORY_API_KEY=

# MEMORY_TEMPERATURE
#
# Controls how "creative" or "deterministic" the AI is when generating
# memory summaries. On a scale of 0.0–2.0:
#   0.0  — always picks the most likely words (identical output each time,
#          very predictable, may feel robotic)
#   0.3  — slightly varied (default, good balance — produces natural
#          summaries without hallucinating)
#   0.7+ — more varied phrasing, higher risk of adding details that weren't
#          actually in the conversation (undesirable for memory accuracy)
#   false — don't set temperature at all; let the API use its own default
#           (varies by provider)
#
# For memory extraction you generally want low values — you want accurate
# summaries, not creative interpretations.
# Default: 0.3
# Required: no
MEMORY_TEMPERATURE=0.3

# OPENCODE_PROVIDER
# OpenCode provider identifier. Used internally for provider-specific behavior.
# Default: (not set)
# Required: no
OPENCODE_PROVIDER=

# OPENCODE_MODEL
# OpenCode model identifier. Used internally for model-specific behavior.
# Default: (not set)
# Required: no
OPENCODE_MODEL=


# ── Auto-Capture ──────────────────────────────────────────────────────────────

# AUTO_CAPTURE_MAX_ITERATIONS
#
# How many rounds of memory extraction run per AI session. Each iteration
# makes one API call to your MEMORY_MODEL to scan recent conversation
# messages and extract interesting facts for your memory store. With 5
# iterations, the server will attempt extraction up to 5 separate times
# per session, each looking at different batches of the conversation.
# Increase for longer conversations (10–15), decrease for short ones (1–3).
# Note: each iteration costs one LLM API call.
# Default: 5
# Required: no
AUTO_CAPTURE_MAX_ITERATIONS=5

# AUTO_CAPTURE_ITERATION_TIMEOUT
#
# Maximum wait time for a single auto-capture API call. 30000 ms = 30
# seconds. If your LLM provider takes longer than this to extract memories
# from a batch of messages, that iteration is cancelled (silently) and the
# server moves on to the next one. Increase if using a slow/self-hosted
# model. Decrease if your provider is fast and you want to fail quicker.
# Default: 30000 (30 seconds)
# Required: no
AUTO_CAPTURE_ITERATION_TIMEOUT=30000

# AUTO_CAPTURE_LANGUAGE
# Language for generated memories. Set to a language code (e.g., "en", "zh") or
# "auto" to let the system detect the language.
# Default: auto
# Required: no
AUTO_CAPTURE_LANGUAGE=auto


# ── Session & Cleanup ─────────────────────────────────────────────────────────

# AI_SESSION_RETENTION_DAYS
#
# How long to keep AI conversation session records. Each time your AI
# agent connects, a session record is created with an expiration date.
# Once a session expires, its conversation transcript and metadata are
# eligible for cleanup (deletion). This does NOT delete the memories
# extracted from those conversations — memories are permanent unless
# explicitly deleted or aged out by AUTO_CLEANUP_RETENTION_DAYS.
#
#   0  — sessions expire immediately (not recommended)
#   7  — keep one week of session data (default, good for recent context)
#   30 — keep a month (useful for debugging or reviewing past sessions)
#   90 — keep a quarter (if you reference old sessions often)
# Default: 7
# Required: no
AI_SESSION_RETENTION_DAYS=7

# AUTO_CLEANUP_RETENTION_DAYS
#
# How long to keep unpinned, non-prompt-linked memories before they're
# eligible for deletion during cleanup. Two important protections:
#   - Pinned memories are NEVER deleted (you mark them as important)
#   - Memories linked to a user prompt are preserved (they have a source)
# Cleanup is NOT automatic by default — you trigger it manually via API
# or from the WebUI dashboard. Set to 0 to disable cleanup entirely.
#
#   0   — keep memories forever (disable cleanup)
#   30  — monthly cleanup
#   90  — quarterly cleanup (default)
#   180 — semi-annual
#   365 — yearly cleanup
# Default: 90
# Required: no
AUTO_CLEANUP_RETENTION_DAYS=90


# ── User Profile ──────────────────────────────────────────────────────────────

# USER_PROFILE_ANALYSIS_INTERVAL
#
# How many AI conversation sessions must pass before the server re-analyzes
# your user profile (re-examines your stored conversations to update known
# preferences, behavior patterns, and workflows). Each session = one AI
# coding session. Lower values update your profile more frequently but
# trigger more LLM API calls. Higher values save API costs but your
# profile lags behind your latest habits.
#
#   1  — analyze after every session (most up-to-date profile, more API
#        calls, higher cost)
#   5  — moderate frequency
#   10 — after every 10 sessions (default, good balance for active users)
#   50 — occasional updates (mainly static profile, very low cost)
# Default: 10
# Required: no
USER_PROFILE_ANALYSIS_INTERVAL=10

# USER_PROFILE_MAX_PREFERENCES
#
# How many "user prefers X over Y" kind of observations the profile keeps.
# When the cap is reached, older preferences may be replaced by new ones.
# Preferences are things like: "prefers TypeScript over JavaScript",
# "likes fast close-captioned video", "favors simplicity over abstraction."
#
#   5  — minimal (keeps only strong preferences)
#   20 — balanced (default)
#   50 — detailed (more memory usage in the profile)
# Default: 20
# Required: no
USER_PROFILE_MAX_PREFERENCES=20

# USER_PROFILE_MAX_PATTERNS
#
# How many recurring behavior patterns the profile tracks. Patterns are
# things like: "tends to work in the morning", "always starts with tests",
# "frequently switches between frontend and backend within a session."
# When the cap is reached, older/weaker patterns may be replaced.
#
#   5  — minimal
#   15 — balanced (default)
#   30 — detailed
# Default: 15
# Required: no
USER_PROFILE_MAX_PATTERNS=15

# USER_PROFILE_MAX_WORKFLOWS
#
# How many identified workflows the profile stores. Workflows are multi-step
# sequences like: "code → test → commit → push" or "research → draft →
# review → finalize." When the cap is reached, older workflows may be
# replaced by new ones.
#
#   3  — minimal
#   10 — balanced (default)
#   25 — detailed
# Default: 10
# Required: no
USER_PROFILE_MAX_WORKFLOWS=10

# USER_PROFILE_CONFIDENCE_DECAY_DAYS
#
# How quickly the system's confidence in your profile insights fades.
# An observation from today counts at full weight; the same observation
# from N days ago counts proportionally less. Shorter periods keep your
# profile tightly focused on recent behavior; longer periods preserve
# older habits.
#
#   7  — fast decay: profile reflects only your very recent work style
#   30 — moderate decay (default): monthly window, good for most users
#   90 — slow decay: preserves quarterly habits
#  180 — very slow: profile reflects half a year of behavior
# Default: 30
# Required: no
USER_PROFILE_CONFIDENCE_DECAY_DAYS=30

# USER_PROFILE_CHANGELOG_RETENTION
#
# How many historical snapshots of your user profile to keep. Each time
# the profile is re-analyzed, the previous version is saved as a changelog
# entry. This lets you review how your profile has evolved over time
# (visible in the WebUI). Higher numbers give more history but use more
# database space (each entry is a full JSON snapshot).
#
#   1  — keep only the latest previous version
#   5  — keep 5 versions (default, reasonable history)
#   20 — keep extensive history (useful for debugging profile drift)
# Default: 5
# Required: no
USER_PROFILE_CHANGELOG_RETENTION=5


# ── Docker Compose Database Service ──────────────────────────────────────────
# These variables are used by the `db` service in docker-compose.yml ONLY.
# They are NOT read by the opencode-memnet server itself.
# If using an external database, you can ignore these.

# POSTGRES_USER
# PostgreSQL username for the Docker db service.
# Default: opencode
POSTGRES_USER=opencode

# POSTGRES_PASSWORD
# PostgreSQL password for the Docker db service.
# Default: opencode
POSTGRES_PASSWORD=opencode

# POSTGRES_DB
# PostgreSQL database name for the Docker db service.
# Default: opencode_mem
POSTGRES_DB=opencode_mem
